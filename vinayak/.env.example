# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# TranzAct credentials
TRANZACT_EMAIL=your@email.com
TRANZACT_PASSWORD=your_password
# Login/auth endpoint and report endpoint live on separate subdomains (confirmed 2026-05-22)
TRANZACT_BASE_URL=https://be.letstranzact.com
TRANZACT_REPORTING_URL=https://reporting.letstranzact.com

# PostgreSQL — Supabase (Phase 1). Docker + local Postgres is the planned
# future migration path; until then, use the Supabase direct connection:
#   Supabase → Settings → Database → Connection string → URI → Direct (port 5432)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# KBrushes company context
DEFAULT_COMPANY_ID=your_company_id

# Rate limiting (TranzAct enforces 10 req/min/machine — stay at 8)
TRANZACT_REQUESTS_PER_MINUTE=8

# Alert threshold: fire if any pipeline hasn't synced in this many hours
SYNC_STALENESS_HOURS=25
