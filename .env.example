# ── Vinayak Brain OS — environment variables ─────────────────────────────────
# Copy this file to .env.local (Next.js) or .env (Python) and fill in real values.
# NEVER commit .env or .env.local to git.

# ── Python (FastAPI + pipelines) ────────────────────────────────────────────

# TranzAct login credentials (KBrushes account)
TRANZACT_EMAIL=your@email.com
TRANZACT_PASSWORD=your_password

# TranzAct API endpoints (confirmed 2026-05-22)
TRANZACT_BASE_URL=https://be.letstranzact.com
TRANZACT_REPORTING_URL=https://reporting.letstranzact.com

# Postgres connection string
# Supabase (recommended): Settings → Database → Connection string → URI → Direct (port 5432)
#   postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Local dev:
#   postgresql://postgres:postgres@localhost:5432/vinayak_brain
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Platform JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme

# Platform admin credentials (Phase 1 single-tenant)
ADMIN_EMAIL=admin@vinayak.com
ADMIN_PASSWORD=changeme

# AES-256 Fernet key for encrypting stored ERP credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Internal API key shared between Next.js BFF and FastAPI
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=changeme

# TranzAct company ID (find in your TranzAct account settings)
DEFAULT_COMPANY_ID=

# Rate limiting (stay under TranzAct's 10 req/min/machine limit)
TRANZACT_REQUESTS_PER_MINUTE=8

# Staleness alert threshold in hours
SYNC_STALENESS_HOURS=25

# ── Next.js (BFF) ─────────────────────────────────────────────────────────────

# FastAPI private URL — server-to-server only, NEVER exposed to the browser.
# Local dev: http://localhost:8000. In production set this to wherever the
# FastAPI service runs (it is read only in server-side route handlers).
FASTAPI_INTERNAL_URL=http://localhost:8000

# Same internal API key as above — server-side only, not NEXT_PUBLIC_
INTERNAL_API_KEY=changeme

# Public app URL (Vercel deployment URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000
